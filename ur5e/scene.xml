<mujoco model="scene">
  <!--
    主场景文件：
      - 包含地面、桌子、要抓取的方块
      - 三个相机：scene_cam（第三人称）、top_cam（俯视）、wrist_cam（手眼，定义在子文件中）
      - 通过 include 引入机械臂+夹爪
  -->

  <include file="ur5e_with_gripper.xml"/>

  <statistic center="0.3 0 0.4" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
  </visual>

  <asset>
    <!-- 天空盒 -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <!-- 地板纹理 -->
    <texture name="groundplane" type="2d" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5"
              texuniform="true" reflectance="0.2"/>
    <!-- 桌子材质 -->
    <material name="table_mat" rgba="0.6 0.45 0.3 1"/>
    <!-- 方块材质 -->
    <material name="cube_mat" rgba="0.9 0.2 0.2 1"/>
  </asset>

  <worldbody>
    <!-- 光源 -->
    <light name="top_light" pos="0 0 2" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light name="side_light" pos="1 1 1.5" dir="-1 -1 -1" diffuse="0.5 0.5 0.5"/>

    <!-- 地面 -->
    <geom name="floor" type="plane" size="0 0 0.05" material="groundplane"
          contype="1" conaffinity="1"/>

    <!-- 桌子：台面高 0.4m -->
    <body name="table" pos="0.5 0 0.2">
      <geom name="table_top" type="box" size="0.3 0.4 0.02" pos="0 0 0.2"
            material="table_mat"/>
      <geom name="leg1" type="box" size="0.02 0.02 0.2" pos="0.25 0.35 0"
            material="table_mat"/>
      <geom name="leg2" type="box" size="0.02 0.02 0.2" pos="-0.25 0.35 0"
            material="table_mat"/>
      <geom name="leg3" type="box" size="0.02 0.02 0.2" pos="0.25 -0.35 0"
            material="table_mat"/>
      <geom name="leg4" type="box" size="0.02 0.02 0.2" pos="-0.25 -0.35 0"
            material="table_mat"/>
              <!-- 放置区标记,在 <worldbody> 里 -->
      <geom name="zone_red"   type="cylinder" size="0.04 0.001"
            pos="-0.1  -0.25 0.22" rgba="0.9 0.1 0.1 0.4"
            contype="0" conaffinity="0"/>
      <geom name="zone_green" type="cylinder" size="0.04 0.001"
            pos="-0.1  0.00 0.22" rgba="0.1 0.9 0.1 0.4"
            contype="0" conaffinity="0"/>
      <geom name="zone_blue"  type="cylinder" size="0.04 0.001"
            pos="-0.1 0.25 0.22" rgba="0.1 0.1 0.9 0.4"
            contype="0" conaffinity="0"/>
    </body>


    <!-- 三色方块 -->
    <body name="cube_red"   pos="0.5  0.10 0.43">
      <freejoint/>
      <geom type="box" size="0.02 0.02 0.02" rgba="0.9 0.1 0.1 1"
            mass="0.05" friction="1 0.005 0.0001"/>
    </body>
    <body name="cube_green" pos="0.5  0.00 0.43">
      <freejoint/>
      <geom type="box" size="0.02 0.02 0.02" rgba="0.1 0.9 0.1 1"
            mass="0.05" friction="1 0.005 0.0001"/>
    </body>
    <body name="cube_blue"  pos="0.5 -0.10 0.43">
      <freejoint/>
      <geom type="box" size="0.02 0.02 0.02" rgba="0.1 0.1 0.9 1"
            mass="0.05" friction="1 0.005 0.0001"/>
    </body>


  <!-- 可抓取小方块 -->
  <body name="cube" pos="0.5 0 0.445">
    <freejoint/>
    <geom name="cube_geom"
          type="box"
          size="0.02 0.02 0.02"
          material="cube_mat"
          mass="0.05"
          contype="1"
          conaffinity="1"
          friction="1 0.005 0.0001"/>
  </body>


    <!-- 第三人称场景相机 -->
    <camera name="scene_cam" pos="1.0 0 1.0"
            xyaxes="0 1 0 -0.6 0.6 0.53" fovy="50"/>

    <camera name="front_cam"
            pos="0.5 -0.5 0.75"
            xyaxes="1 0 0 0 0.55 0.83"
            fovy="50"/>
    <!-- =========== 在这里添加 target 刚体 =========== -->
    <body name="target" pos="0.5 0 .5" quat="0 1 0 0" mocap="true">
      <geom type="box" size=".001 .001 .001" contype="0" conaffinity="0" rgba=".6 .3 .3 .5"/>
      <site type="sphere" size="0.001" rgba="0 0 1 1" group="1"/>
    </body>
    <!-- ============================================== -->

  </worldbody>
</mujoco>

